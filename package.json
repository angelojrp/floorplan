{
  "name": "@angelojrp/floorplan",
  "version": "1.0.0",
  "description": "Text-to-floorplan renderer — descreva plantas baixas em YAML e renderize como SVG",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "floorplan": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "keywords": ["floorplan", "plant-baixa", "svg", "construction", "mermaid", "dxf", "yaml", "architecture"],
  "files": [
    "dist/",
    "docs/AI_GUIDE.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/angelojrp/floorplan"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.6.1",
    "zod": "^3.23.8",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
